{
  "name": "@levelup/functions-sdk-v1",
  "version": "0.1.0",
  "private": true,
  "description": "Deployable v1.* Cloud Functions codebase — thin makeCallable/makeTrigger/makeScheduler shells over @levelup/services (additive; legacy identity/levelup/autograde/analytics codebases untouched)",
  "type": "module",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "clean": "rm -rf lib",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:supabase": "node scripts/verify-supabase-telemetry.mjs"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^5.6.0",
    "@google/generative-ai": "^0.21.0",
    "@supabase/supabase-js": "2.100.0",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@levelup/access": "workspace:*",
    "@levelup/ai": "workspace:*",
    "@levelup/api-contract": "file:.local-deps/api-contract",
    "@levelup/domain": "file:.local-deps/domain",
    "@levelup/functions-adapters": "workspace:*",
    "@levelup/services": "workspace:*",
    "tsup": "^8",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": "20"
  }
}
