# Canonical v2 Firestore namespace used by the application data layer.
LVLUP_COLLECTION_PREFIX=v2_

# Supabase is used only as the server-side LLM telemetry store.
SUPABASE_URL=https://fvgrillvdzuvzxpbgdem.supabase.co

# Obtain this from Supabase project settings and configure it through the
# Firebase/Google secret runtime. Never commit it or expose it through VITE_*,
# NEXT_PUBLIC_*, or EXPO_PUBLIC_* variables.
SUPABASE_SERVICE_ROLE_KEY=
