---

---

<section class="py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="scroll-reveal relative overflow-hidden rounded-2xl bg-slate-950 px-8 py-16 text-center sm:px-12 lg:px-20 lg:py-20">

      <!-- Dot-grid overlay -->
      <div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(white 1px, transparent 1px); background-size: 24px 24px;"></div>

      <!-- Radial glow -->
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <div class="h-[500px] w-[700px] rounded-full bg-primary/20 blur-[120px]"></div>
      </div>

      <!-- Top border accent -->
      <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-primary/60 to-transparent"></div>

      <!-- Content -->
      <div class="relative z-10">
        <!-- Badge -->
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-4 py-1.5 text-sm font-medium text-emerald-400">
          <span class="relative flex h-2 w-2 shrink-0">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400/70"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-400"></span>
          </span>
          Live Demo Available
        </div>

        <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
          See What Auto-LevelUp
          <br class="hidden sm:block" />
          <span class="bg-gradient-to-r from-primary via-blue-400 to-primary bg-[length:200%_auto] bg-clip-text text-transparent cta-gradient">
            Can Do for Your School
          </span>
        </h2>

        <p class="mx-auto mt-5 max-w-xl text-lg text-white/60 leading-relaxed">
          30 minutes. A live walkthrough built around your school's real needs —
          AI grading, adaptive learning, and real-time analytics.
        </p>

        <!-- Stats strip -->
        <div class="my-10 flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
          {[
            { value: '8 min', label: 'to grade a class' },
            { value: '<1 hr', label: 'to set up' },
            { value: '24/7', label: 'AI tutor' },
          ].map((stat) => (
            <div class="flex flex-col items-center">
              <span class="text-2xl font-extrabold text-white">{stat.value}</span>
              <span class="text-xs text-white/40 mt-0.5">{stat.label}</span>
            </div>
          ))}
        </div>

        <!-- CTAs -->
        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="/demo"
            class="inline-flex items-center justify-center gap-2 rounded-lg bg-white px-8 py-4 text-base font-semibold text-slate-900 shadow-lg transition-all duration-150 hover:bg-slate-100 hover:shadow-xl active:scale-[0.98]"
          >
            Book a Demo
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 rounded-lg border border-white/15 bg-white/8 px-8 py-4 text-base font-semibold text-white transition-all duration-150 hover:border-white/25 hover:bg-white/12 active:scale-[0.98]"
          >
            Talk to Sales
          </a>
        </div>

        <p class="mt-5 text-sm text-white/30">
          No commitment. No credit card. Just a conversation about what's possible.
        </p>
      </div>

      <!-- Bottom border accent -->
      <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
    </div>
  </div>
</section>

<style>
  .cta-gradient {
    animation: gradient-shift 5s ease infinite;
    background-size: 200% auto;
  }
  @keyframes gradient-shift {
    0%, 100% { background-position: 0% center; }
    50% { background-position: 100% center; }
  }
  @media (prefers-reduced-motion: reduce) {
    .cta-gradient { animation: none; }
  }
</style>
