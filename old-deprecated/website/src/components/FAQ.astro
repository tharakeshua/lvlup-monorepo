---
const faqs = [
  {
    question: 'What is Auto-LevelUp?',
    answer: 'Auto-LevelUp is an AI education platform built for schools. It has two products that work together: LvlUp Spaces gives every student a personalised AI tutor and adaptive learning path. AutoGrade lets teachers scan handwritten exams with any phone and get fully graded, feedback-rich reports in minutes. Schools, teachers, students, and parents each get their own dashboard — all connected in real time.',
  },
  {
    question: 'How does AutoGrade work?',
    answer: 'A teacher photographs answer sheets using any smartphone. The AI reads the handwriting, maps each answer to the right question, and grades everything against the teacher\'s rubric — all at once, for the whole class. Every student gets a detailed report showing where marks were earned and where to improve. Teachers can review and override any grade with one click. The whole process takes about 8 minutes for a class of 40.',
  },
  {
    question: 'Will this work for my school, regardless of size?',
    answer: 'Yes. Auto-LevelUp works for a single classroom or an entire school district. Each school\'s data is fully isolated and secure. Whether you have 30 students or 3,000, the platform scales with you — and every school gets its own branding, settings, and admin controls.',
  },
  {
    question: 'How does the student experience work?',
    answer: 'Students earn XP for completing lessons, maintaining streaks, and hitting learning goals. They progress through achievement tiers — from Bronze to Diamond — and see their rank on weekly leaderboards. The AI tutor is available 24/7 to help with questions, and the difficulty adjusts automatically so every student is appropriately challenged.',
  },
  {
    question: 'Can parents see how their child is doing?',
    answer: 'Yes. Parents get real-time alerts when exam scores drop or when a child hasn\'t been active. They can see strengths, weak topics, and specific AI recommendations — not just a number on a page. Downloadable PDF progress reports make it easy to prepare for tutor sessions or parent-teacher meetings.',
  },
  {
    question: 'How is student data protected?',
    answer: 'Every school\'s data is fully isolated — no other institution can access it. All data is encrypted, and staff access is controlled through granular permissions. Schools bring their own AI credentials, so usage costs stay on their own billing account. We never sell student data.',
  },
  {
    question: 'Does the AI replace teachers?',
    answer: 'No. The AI handles the repetitive work — grading, flagging at-risk students, adjusting difficulty — so teachers can focus on the work that matters: teaching, mentoring, and making judgment calls. Teachers always have the final word. Every AI grade can be reviewed and overridden with a documented reason.',
  },
  {
    question: 'How do we get started?',
    answer: 'Book a 30-minute demo and we\'ll walk you through the platform using your school\'s context. From there, setup takes under an hour: create your school profile, import your users with a CSV, and your teachers are ready to build their first learning space or grade their first exam.',
  },
];
---

<section id="faq" class="relative py-20 sm:py-28">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center scroll-reveal">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-blue-200 bg-blue-50 px-4 py-1.5 text-sm font-semibold text-blue-700">
        <svg class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
        </svg>
        Got Questions?
      </div>
      <h2 class="section-heading">Frequently Asked Questions</h2>
      <p class="section-subheading">
        Everything you need to know about Auto-LevelUp — answered honestly.
      </p>
    </div>

    <!-- FAQ list -->
    <div class="mt-12 divide-y divide-slate-100">
      {faqs.map((faq, i) => (
        <div class="faq-item group" style={`transition-delay: ${i * 40}ms`}>
          <button
            class="faq-trigger flex w-full items-start gap-4 py-5 text-left"
            aria-expanded="false"
            aria-controls={`faq-answer-${i}`}
            id={`faq-trigger-${i}`}
          >
            <!-- Number -->
            <span class="faq-num mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-slate-100 text-[11px] font-bold text-slate-400 transition-all duration-200 group-hover:bg-blue-50 group-hover:text-blue-600">
              {String(i + 1).padStart(2, '0')}
            </span>

            <!-- Question -->
            <span class="flex-1 text-sm font-semibold leading-snug text-slate-800 pr-2">{faq.question}</span>

            <!-- Chevron -->
            <span class="faq-icon mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-400 shadow-sm transition-all duration-200">
              <svg class="faq-chevron h-3 w-3 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </span>
          </button>

          <!-- Answer panel -->
          <div
            class="faq-content overflow-hidden"
            id={`faq-answer-${i}`}
            role="region"
            aria-labelledby={`faq-trigger-${i}`}
            style="max-height: 0; transition: max-height 0.32s cubic-bezier(0.4, 0, 0.2, 1);"
          >
            <div class="faq-body ml-10 pb-5 pr-8">
              <div class="rounded-xl border border-slate-100 bg-slate-50 px-5 py-4">
                <p class="text-sm leading-relaxed text-slate-600">{faq.answer}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Footer CTA -->
    <div class="mt-12 scroll-reveal rounded-2xl border border-slate-200 bg-slate-50 p-6 text-center">
      <p class="text-sm font-medium text-slate-700">Still have questions?</p>
      <p class="mt-1 text-xs text-slate-500">We're happy to walk you through anything live.</p>
      <div class="mt-4 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href="/demo"
          class="inline-flex items-center gap-2 rounded-xl bg-gray-900 px-6 py-2.5 text-sm font-bold text-white shadow-sm transition-all hover:bg-gray-800 hover:-translate-y-px"
        >
          Book a Free Demo
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-6 py-2.5 text-sm font-semibold text-slate-700 shadow-sm transition-all hover:border-slate-300 hover:bg-slate-50"
        >
          Send a Message
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  .faq-item[data-open] .faq-num {
    background-color: rgb(239 246 255);
    color: rgb(29 78 216);
  }
  .faq-item[data-open] .faq-icon {
    border-color: rgb(191 219 254);
    background-color: rgb(239 246 255);
    color: rgb(37 99 235);
  }
</style>

<script>
  function initFaq() {
    document.querySelectorAll('.faq-trigger').forEach((trigger) => {
      if ((trigger as HTMLElement).dataset.initialized) return;
      (trigger as HTMLElement).dataset.initialized = 'true';

      trigger.addEventListener('click', () => {
        const item = trigger.closest('.faq-item') as HTMLElement;
        const content = item.querySelector('.faq-content') as HTMLElement;
        const chevron = item.querySelector('.faq-chevron') as HTMLElement;
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';

        // Close all others
        document.querySelectorAll('.faq-item').forEach((other) => {
          if (other === item) return;
          const oc = other.querySelector('.faq-content') as HTMLElement;
          const och = other.querySelector('.faq-chevron') as HTMLElement;
          oc.style.maxHeight = '0';
          other.querySelector('.faq-trigger')!.setAttribute('aria-expanded', 'false');
          och.classList.remove('rotate-180');
          (other as HTMLElement).removeAttribute('data-open');
        });

        if (isOpen) {
          content.style.maxHeight = '0';
          chevron.classList.remove('rotate-180');
          item.removeAttribute('data-open');
          trigger.setAttribute('aria-expanded', 'false');
        } else {
          content.style.maxHeight = content.scrollHeight + 'px';
          chevron.classList.add('rotate-180');
          item.setAttribute('data-open', '');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  }

  initFaq();
  document.addEventListener('astro:after-swap', initFaq);
</script>
