    num: '01',
    role: 'Schools',
    color: 'primary',
    tagline: 'Run a data-driven school — without a data team',
    description: 'School-wide dashboards, staff controls, and AI cost visibility in one place',
    features: [
      'School-wide performance dashboard with at-risk counts',
      'Full AI cost tracking — per exam, per month, no surprises',
      'Granular staff permissions for every role',
      'Data export for board reviews and audits',
      'Bulk user management with CSV import',
      'Complete data isolation for your school',
    ],
  },
  {
    num: '02',
    role: 'Teachers',
    color: 'success',
    tagline: 'Grade less. Teach more. Know more.',
    description: 'Get your weekends back — AI handles the grading, you handle the teaching',
    features: [
      'Grade an entire class exam in 8 minutes',
      'At-risk alerts surface struggling students early',
      'Per-question analytics show which concepts need reteaching',
      'Build reusable question banks and rubric presets',
      'Override any AI grade — you always have the final word',
      '15 question types from quizzes to essays to coding',
    ],
  },
  {
    num: '03',
    role: 'Students',
    color: 'info',
    tagline: 'Learning feels like leveling up',
    description: 'A 24/7 AI tutor, adaptive challenges, and rewards that make studying feel like progress',
    features: [
      '24/7 AI tutor that helps without giving answers away',
      'Difficulty that adjusts to your level automatically',
      'XP, levels, badges, and leaderboards',
      'Practice mode — retry without hurting your grade',
      'Detailed exam feedback that explains where marks were lost',
      'Streaks and achievements that reward daily effort',
    ],
  },
  {
    num: '04',
    role: 'Parents',
    color: 'warning',
    tagline: 'No more waiting for the report card',
    description: 'Real-time alerts, progress reports, and AI recommendations for every child',
    features: [
      'Same-day alerts when exam scores drop',
      'See strengths, weak topics, and what to focus on next',
      'Download PDF progress reports for tutor sessions',
      'Side-by-side comparison for multiple children',
      'Choose which notifications you want to receive',
      'AI recommendations specific to your child',
    ],
