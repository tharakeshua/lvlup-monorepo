---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const highlights = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />`,
    title: 'AI Grading in 8 Minutes',
    desc: 'See AutoGrade turn a stack of handwritten papers into detailed reports — live.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />`,
    title: 'Adaptive AI Tutor',
    desc: 'Watch how students get personalised guidance without being given the answer.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />`,
    title: 'Real-Time Analytics',
    desc: 'School-wide dashboards, at-risk flags, and parent alerts — all connected.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />`,
    title: 'Setup in Under an Hour',
    desc: 'CSV import, custom branding, and full data isolation — from day one.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Book a Demo - Auto LevelUp',
  description: 'Book a free 30-minute demo of Auto LevelUp. See AI grading, adaptive learning, and real-time analytics built for your school.',
};
---

<Layout
  title="Book a Demo — Auto LevelUp"
  description="Book a free 30-minute live demo of Auto LevelUp. See AI grading in action, the student learning experience, and real-time parent dashboards."
  jsonLd={jsonLd}
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Book a Demo', url: '/demo' }]}
>
  <Nav />
  <main id="main-content">
    <section class="relative overflow-hidden pt-24 pb-20 sm:pt-32 sm:pb-28">
      <!-- Dot-grid background -->
      <div class="absolute inset-0 -z-10" style="background-image: radial-gradient(hsl(var(--primary) / 0.1) 1px, transparent 1px); background-size: 28px 28px;"></div>
      <div class="absolute inset-x-0 top-0 -z-10 h-48 bg-gradient-to-b from-background to-transparent"></div>
      <div class="absolute inset-x-0 bottom-0 -z-10 h-48 bg-gradient-to-t from-background to-transparent"></div>
      <div class="absolute top-1/3 left-1/2 -z-10 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/6 blur-[120px]"></div>

      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-12 lg:grid-cols-2 lg:gap-16 lg:items-start">

          <!-- Left: Value proposition -->
          <div class="lg:sticky lg:top-28">
            <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/6 px-4 py-1.5 text-sm font-medium text-primary">
              <span class="relative flex h-2 w-2">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary/75"></span>
                <span class="relative inline-flex h-2 w-2 rounded-full bg-primary"></span>
              </span>
              Free 30-Minute Demo
            </div>

            <h1 class="text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-[3.25rem] lg:leading-[1.15]">
              See Auto-LevelUp
              <br />
              <span class="bg-gradient-to-r from-primary via-blue-400 to-primary bg-[length:200%_auto] bg-clip-text text-transparent demo-gradient">
                Built for Your School
              </span>
            </h1>

            <p class="mt-5 text-lg leading-relaxed text-muted-foreground">
              A live walkthrough tailored to your school's context — not a generic slide deck.
              We'll show you exactly what day one looks like.
            </p>

            <!-- What you'll see -->
            <div class="mt-8 space-y-4">
              {highlights.map((h) => (
                <div class="flex items-start gap-4">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <Fragment set:html={h.icon} />
                    </svg>
                  </div>
                  <div>
                    <p class="font-semibold">{h.title}</p>
                    <p class="mt-0.5 text-sm text-muted-foreground">{h.desc}</p>
                  </div>
                </div>
              ))}
            </div>

            <!-- Trust -->
            <div class="mt-10 rounded-xl border border-border bg-card p-5">
              <div class="flex items-center gap-3">
                <div class="flex -space-x-2">
                  {[['SK','from-violet-500 to-purple-600'],['MJ','from-blue-500 to-cyan-500'],['AR','from-emerald-500 to-teal-500']].map(([i,g]) => (
                    <div class={`flex h-9 w-9 items-center justify-center rounded-full border-2 border-background bg-gradient-to-br ${g} text-[10px] font-bold text-white`}>{i}</div>
                  ))}
                </div>
                <div>
                  <p class="text-sm font-semibold">Trusted by 500+ schools</p>
                  <p class="text-xs text-muted-foreground">No commitment · No credit card</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Right: Form card -->
          <div class="relative">
            <div class="absolute inset-x-0 top-0 h-px rounded-t-2xl bg-gradient-to-r from-transparent via-primary/50 to-transparent"></div>
            <div class="rounded-2xl border border-border bg-card shadow-xl">
              <div class="p-7 sm:p-9">
                <h2 class="text-2xl font-bold">Book Your Free Demo</h2>
                <p class="mt-1.5 text-sm text-muted-foreground">
                  Fill in your details and we'll reach out to schedule a time that works for you.
                </p>

                <form id="demo-form" class="mt-7 space-y-5" novalidate>

                  <!-- Error summary -->
                  <div id="form-error-summary" class="hidden rounded-lg border border-destructive/30 bg-destructive/10 px-4 py-3 text-sm text-destructive" role="alert">
                    Please fix the errors below before submitting.
                  </div>

                  <!-- Name row -->
                  <div class="grid gap-5 sm:grid-cols-2">
                    <div class="space-y-1.5">
                      <label for="firstName" class="block text-sm font-medium">First Name <span class="text-destructive">*</span></label>
                      <input
                        id="firstName" name="firstName" type="text" required autocomplete="given-name"
                        placeholder="Priya"
                        aria-describedby="firstName-error"
                        class="demo-input w-full rounded-lg border border-input bg-background px-3.5 py-2.5 text-sm shadow-sm outline-none transition-all duration-150 placeholder:text-muted-foreground/50 focus:border-primary focus:ring-2 focus:ring-primary/15"
                      />
                      <p class="hidden text-xs text-destructive" id="firstName-error" data-error="firstName" role="alert">Please enter your first name</p>
                    </div>
                    <div class="space-y-1.5">
                      <label for="lastName" class="block text-sm font-medium">Last Name <span class="text-destructive">*</span></label>
                      <input
                        id="lastName" name="lastName" type="text" required autocomplete="family-name"
                        placeholder="Sharma"
                        aria-describedby="lastName-error"
                        class="demo-input w-full rounded-lg border border-input bg-background px-3.5 py-2.5 text-sm shadow-sm outline-none transition-all duration-150 placeholder:text-muted-foreground/50 focus:border-primary focus:ring-2 focus:ring-primary/15"
                      />
                      <p class="hidden text-xs text-destructive" id="lastName-error" data-error="lastName" role="alert">Please enter your last name</p>
                    </div>
                  </div>

                  <!-- Work email -->
                  <div class="space-y-1.5">
                    <label for="email" class="block text-sm font-medium">Work Email <span class="text-destructive">*</span></label>
                    <div class="relative">
                      <svg class="pointer-events-none absolute left-3.5 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                      </svg>
                      <input
                        id="email" name="email" type="email" required autocomplete="email"
                        placeholder="priya@school.edu"
                        aria-describedby="email-error"
                        class="demo-input w-full rounded-lg border border-input bg-background py-2.5 pr-3.5 pl-10 text-sm shadow-sm outline-none transition-all duration-150 placeholder:text-muted-foreground/50 focus:border-primary focus:ring-2 focus:ring-primary/15"
                      />
                    </div>
                    <p class="hidden text-xs text-destructive" id="email-error" data-error="email" role="alert">Please enter a valid email address</p>
                  </div>

                  <!-- Phone -->
                  <div class="space-y-1.5">
                    <label for="phone" class="block text-sm font-medium">Phone Number</label>
                    <div class="relative">
                      <svg class="pointer-events-none absolute left-3.5 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                      </svg>
                      <input
                        id="phone" name="phone" type="tel" autocomplete="tel"
                        placeholder="+91 98765 43210"
                        class="demo-input w-full rounded-lg border border-input bg-background py-2.5 pr-3.5 pl-10 text-sm shadow-sm outline-none transition-all duration-150 placeholder:text-muted-foreground/50 focus:border-primary focus:ring-2 focus:ring-primary/15"
                      />
                    </div>
                  </div>

                  <!-- School + Role row -->
                  <div class="grid gap-5 sm:grid-cols-2">
                    <div class="space-y-1.5">
                      <label for="organization" class="block text-sm font-medium">School / Organization <span class="text-destructive">*</span></label>
                      <div class="relative">
                        <svg class="pointer-events-none absolute left-3.5 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" />
                        </svg>
                        <input
                          id="organization" name="organization" type="text" required autocomplete="organization"
                          placeholder="DPS New Delhi"
                          aria-describedby="organization-error"
                          class="demo-input w-full rounded-lg border border-input bg-background py-2.5 pr-3.5 pl-10 text-sm shadow-sm outline-none transition-all duration-150 placeholder:text-muted-foreground/50 focus:border-primary focus:ring-2 focus:ring-primary/15"
                        />
                      </div>
                      <p class="hidden text-xs text-destructive" id="organization-error" data-error="organization" role="alert">Please enter your school name</p>
                    </div>

                    <div class="space-y-1.5">
                      <label for="role" class="block text-sm font-medium">Your Role <span class="text-destructive">*</span></label>
                      <div class="relative">
                        <select
                          id="role" name="role" required
                          aria-describedby="role-error"
                          class="demo-input w-full appearance-none rounded-lg border border-input bg-background px-3.5 py-2.5 text-sm shadow-sm outline-none transition-all duration-150 focus:border-primary focus:ring-2 focus:ring-primary/15"
                        >
                          <option value="">Select your role</option>
                          <option value="administrator">School Administrator</option>
                          <option value="principal">Principal</option>
                          <option value="teacher">Teacher</option>
                          <option value="district">District Administrator</option>
                          <option value="other">Other</option>
                        </select>
                        <svg class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                        </svg>
                      </div>
                      <p class="hidden text-xs text-destructive" id="role-error" data-error="role" role="alert">Please select your role</p>
                    </div>
                  </div>

                  <!-- School size + Preferred time row -->
                  <div class="grid gap-5 sm:grid-cols-2">
                    <div class="space-y-1.5">
                      <label for="schoolSize" class="block text-sm font-medium">Number of Students</label>
                      <div class="relative">
                        <select
                          id="schoolSize" name="schoolSize"
                          class="demo-input w-full appearance-none rounded-lg border border-input bg-background px-3.5 py-2.5 text-sm shadow-sm outline-none transition-all duration-150 focus:border-primary focus:ring-2 focus:ring-primary/15"
                        >
                          <option value="">Select range</option>
                          <option value="under-100">Under 100</option>
                          <option value="100-500">100 – 500</option>
                          <option value="500-1000">500 – 1,000</option>
                          <option value="1000-3000">1,000 – 3,000</option>
                          <option value="3000+">3,000+</option>
                        </select>
                        <svg class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                        </svg>
                      </div>
                    </div>

                    <div class="space-y-1.5">
                      <label for="preferredTime" class="block text-sm font-medium">Preferred Time</label>
                      <div class="relative">
                        <select
                          id="preferredTime" name="preferredTime"
                          class="demo-input w-full appearance-none rounded-lg border border-input bg-background px-3.5 py-2.5 text-sm shadow-sm outline-none transition-all duration-150 focus:border-primary focus:ring-2 focus:ring-primary/15"
                        >
                          <option value="">Any time works</option>
                          <option value="morning">Morning (9am – 12pm)</option>
                          <option value="afternoon">Afternoon (12pm – 4pm)</option>
                          <option value="evening">Evening (4pm – 7pm)</option>
                        </select>
                        <svg class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                        </svg>
                      </div>
                    </div>
                  </div>

                  <!-- What to see -->
                  <div class="space-y-1.5">
                    <label class="block text-sm font-medium">What would you like to see? <span class="text-muted-foreground font-normal">(optional)</span></label>
                    <div class="grid grid-cols-2 gap-2">
                      {[
                        { id: 'see-grading',   label: 'AI Grading (AutoGrade)' },
                        { id: 'see-tutor',     label: 'Student AI Tutor' },
                        { id: 'see-analytics', label: 'Analytics & Dashboards' },
                        { id: 'see-parent',    label: 'Parent Portal' },
                      ].map((opt) => (
                        <label class="demo-checkbox-label flex cursor-pointer items-center gap-2.5 rounded-lg border border-border bg-background px-3 py-2.5 text-sm transition-colors hover:border-primary/30 hover:bg-primary/4 has-[:checked]:border-primary/40 has-[:checked]:bg-primary/6">
                          <input type="checkbox" name="interests" value={opt.id} class="h-4 w-4 rounded border-input accent-primary" />
                          {opt.label}
                        </label>
                      ))}
                    </div>
                  </div>

                  <!-- Notes -->
                  <div class="space-y-1.5">
                    <label for="message" class="block text-sm font-medium">Anything else we should know? <span class="text-muted-foreground font-normal">(optional)</span></label>
                    <textarea
                      id="message" name="message"
                      rows="3"
                      placeholder="e.g. We have 3 campuses, we'd like to see district-level reporting..."
                      class="demo-input w-full resize-none rounded-lg border border-input bg-background px-3.5 py-2.5 text-sm shadow-sm outline-none transition-all duration-150 placeholder:text-muted-foreground/50 focus:border-primary focus:ring-2 focus:ring-primary/15"
                    ></textarea>
                  </div>

                  <!-- Submit -->
                  <div class="pt-1">
                    <div class="relative">
                      <span id="btn-pulse" class="absolute inset-0 rounded-xl bg-slate-900/25 demo-pulse" aria-hidden="true"></span>
                      <button
                        type="submit"
                        id="submit-btn"
                        class="relative flex w-full items-center justify-center gap-2.5 rounded-xl bg-slate-900 px-6 py-4 text-base font-bold text-white shadow-xl shadow-slate-900/25 transition-all duration-150 hover:bg-slate-800 hover:shadow-2xl hover:-translate-y-0.5 active:translate-y-0 disabled:cursor-not-allowed disabled:opacity-60"
                      >
                        <span id="btn-shimmer" class="absolute inset-0 hidden overflow-hidden rounded-xl">
                          <span class="absolute inset-0 -translate-x-full animate-[shimmer_1.4s_infinite] bg-gradient-to-r from-transparent via-white/10 to-transparent"></span>
                        </span>
                        <svg id="submit-icon" class="h-4 w-4 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5l4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z" />
                        </svg>
                        <span id="submit-spinner" class="hidden items-center gap-1">
                          <span class="h-1.5 w-1.5 rounded-full bg-white animate-[bounce_0.8s_0ms_infinite]"></span>
                          <span class="h-1.5 w-1.5 rounded-full bg-white animate-[bounce_0.8s_150ms_infinite]"></span>
                          <span class="h-1.5 w-1.5 rounded-full bg-white animate-[bounce_0.8s_300ms_infinite]"></span>
                        </span>
                        <span id="submit-text">Book My Free Demo</span>
                      </button>
                    </div>
                    <p class="mt-3 text-center text-xs text-muted-foreground">
                      No commitment · No credit card · We'll reach out within 24 hours
                    </p>
                  </div>
                </form>

                <!-- Success state -->
                <div id="form-success" class="hidden py-12 text-center" role="alert">
                  <div class="mx-auto mb-5 flex h-16 w-16 items-center justify-center rounded-full bg-success/10">
                    <svg class="h-8 w-8 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                  </div>
                  <h3 class="text-2xl font-bold">You're on the list!</h3>
                  <p class="mt-2 text-sm text-muted-foreground max-w-xs mx-auto">
                    We'll reach out within 24 hours to schedule your personalised demo.
                  </p>
                  <a href="/" class="mt-6 inline-flex items-center gap-2 rounded-lg border border-border bg-background px-5 py-2.5 text-sm font-medium text-foreground shadow-sm transition-all hover:border-primary/30 hover:bg-primary/5">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                    </svg>
                    Back to Home
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .demo-gradient {
    animation: gradient-shift 5s ease infinite;
    background-size: 200% auto;
  }
  @keyframes gradient-shift {
    0%, 100% { background-position: 0% center; }
    50% { background-position: 100% center; }
  }

  .demo-pulse {
    animation: demo-btn-pulse 2.4s ease-out infinite;
  }
  @keyframes demo-btn-pulse {
    0%   { transform: scale(1);    opacity: 0.5; }
    70%  { transform: scale(1.08); opacity: 0; }
    100% { transform: scale(1.08); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .demo-gradient, .demo-pulse { animation: none; }
  }
</style>

<script>
  const APPSCRIPT_URL =
    'https://script.google.com/macros/s/AKfycbz1jjcjiEsgGtHRBboA8T7ASowoWinyvykYeYIgKDdE5E5Iykx32kpjTR1YMDr5Uv6cOA/exec';

  function initDemoForm() {
    const form = document.getElementById('demo-form') as HTMLFormElement | null;
    const submitBtn = document.getElementById('submit-btn');
    const submitText = document.getElementById('submit-text');
    const submitSpinner = document.getElementById('submit-spinner');
    const submitIcon = document.getElementById('submit-icon');
    const shimmer = document.getElementById('btn-shimmer');
    const successMsg = document.getElementById('form-success');
    const errorSummary = document.getElementById('form-error-summary');

    if (!form || !submitBtn) return;
    if (form.dataset.initialized) return;
    form.dataset.initialized = 'true';
    const _submitBtn = submitBtn;

    function showError(field: string) {
      const el = document.querySelector(`[data-error="${field}"]`);
      const input = document.getElementById(field);
      if (el) el.classList.remove('hidden');
      if (input) {
        input.setAttribute('aria-invalid', 'true');
        input.classList.add('border-destructive');
        input.classList.remove('border-input');
      }
    }

    function hideErrors() {
      document.querySelectorAll('[data-error]').forEach((el) => el.classList.add('hidden'));
      document.querySelectorAll('[aria-invalid]').forEach((el) => {
        el.removeAttribute('aria-invalid');
        el.classList.remove('border-destructive');
        el.classList.add('border-input');
      });
      errorSummary?.classList.add('hidden');
    }

    function validateEmail(email: string) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    }

    function setLoading(loading: boolean) {
      if (loading) {
        if (submitText) submitText.textContent = 'Booking…';
        submitSpinner?.classList.remove('hidden');
        submitSpinner?.classList.add('flex');
        submitIcon?.classList.add('hidden');
        shimmer?.classList.remove('hidden');
        _submitBtn.setAttribute('disabled', 'true');
      } else {
        if (submitText) submitText.textContent = 'Book My Free Demo';
        submitSpinner?.classList.add('hidden');
        submitSpinner?.classList.remove('flex');
        submitIcon?.classList.remove('hidden');
        shimmer?.classList.add('hidden');
        _submitBtn.removeAttribute('disabled');
      }
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      hideErrors();

      const data = new FormData(form);
      const str = (key: string) => (data.get(key) as string | null) ?? '';
      let valid = true;
      const invalidFields: string[] = [];

      for (const field of ['firstName', 'lastName', 'email', 'organization', 'role']) {
        if (!str(field).trim()) {
          showError(field);
          invalidFields.push(field);
          valid = false;
        }
      }

      const email = str('email').trim();
      if (email && !validateEmail(email)) {
        showError('email');
        if (!invalidFields.includes('email')) invalidFields.push('email');
        valid = false;
      }

      if (!valid) {
        errorSummary?.classList.remove('hidden');
        const firstEl = document.getElementById(invalidFields[0]);
        if (firstEl) { firstEl.scrollIntoView({ behavior: 'smooth', block: 'center' }); firstEl.focus(); }
        return;
      }

      setLoading(true);

      // Collect checked interests
      const interests = Array.from(form.querySelectorAll('input[name="interests"]:checked'))
        .map((el) => (el as HTMLInputElement).value)
        .join(', ');

      // Pack all demo-specific fields into message (sheet only has these columns)
      const messageParts: string[] = [];
      const phone = str('phone').trim();
      if (phone)                            messageParts.push('Phone: ' + phone);
      if (str('schoolSize'))               messageParts.push('School size: ' + str('schoolSize'));
      if (str('preferredTime'))            messageParts.push('Preferred time: ' + str('preferredTime'));
      if (interests)                        messageParts.push('Interests: ' + interests);
      const msgNote = str('message').trim();
      if (msgNote)                          messageParts.push('Notes: ' + msgNote);
      const message = messageParts.join(' | ') || 'Demo request';

      const params = new URLSearchParams({
        firstName:    str('firstName').trim(),
        lastName:     str('lastName').trim(),
        email:        str('email').trim(),
        organization: str('organization').trim(),
        role:         str('role'),
        inquiryType:  'demo',
        message:      message,
      });

      const url = APPSCRIPT_URL + '?' + params.toString();
      console.log('[Demo] GET:', url);

      try {
        await fetch(url, { method: 'GET', redirect: 'follow' });
      } catch (err) {
        console.warn('[Demo] Fetch error (data still likely saved):', err);
      } finally {
        setLoading(false);
        form.classList.add('hidden');
        successMsg?.classList.remove('hidden');
      }
    });

    // Clear field error on change
    form.querySelectorAll('input, select, textarea').forEach((el) => {
      el.addEventListener('change', () => {
        const errorEl = document.querySelector(`[data-error="${el.id}"]`);
        if (errorEl && !errorEl.classList.contains('hidden')) {
          errorEl.classList.add('hidden');
          el.removeAttribute('aria-invalid');
          el.classList.remove('border-destructive');
          el.classList.add('border-input');
        }
      });
    });
  }

  initDemoForm();
  document.addEventListener('astro:after-swap', initDemoForm);
</script>
