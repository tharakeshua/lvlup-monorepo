---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const APPSCRIPT_URL =
  'https://script.google.com/macros/s/AKfycbz1jjcjiEsgGtHRBboA8T7ASowoWinyvykYeYIgKDdE5E5Iykx32kpjTR1YMDr5Uv6cOA/exec';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Us - Auto LevelUp',
  description: 'Get in touch with the Auto LevelUp team. Request a demo, ask questions, or get support.',
  mainEntity: {
    '@type': 'Organization',
    name: 'Auto LevelUp',
    email: 'hello@autolevelup.com',
    contactPoint: {
      '@type': 'ContactPoint',
      contactType: 'sales',
      email: 'sales@autolevelup.com',
    },
  },
};
---

<Layout
  title="Contact Us - Auto LevelUp"
  description="Get in touch with the Auto LevelUp team. Request a demo, ask a question, or get help with your account."
  jsonLd={jsonLd}
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Contact', url: '/contact' }]}
>
  <Nav />
  <main id="main-content">
    <section class="relative overflow-hidden pt-28 pb-20 sm:pt-36 sm:pb-28">
      <!-- Background decoration -->
      <div class="pointer-events-none absolute inset-0 -z-10">
        <div class="absolute -top-40 -right-40 h-[600px] w-[600px] rounded-full bg-primary/5 blur-3xl"></div>
        <div class="absolute -bottom-40 -left-40 h-[500px] w-[500px] rounded-full bg-primary/3 blur-3xl"></div>
      </div>

      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <!-- Section header -->
        <div class="mx-auto mb-14 max-w-2xl text-center">
          <div class="mb-4 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/8 px-4 py-1.5 text-sm font-medium text-primary">
            <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
            Get in Touch
          </div>
          <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
            Let's Talk About Your<br />
            <span class="bg-gradient-to-r from-primary to-blue-400 bg-clip-text text-transparent">School's Future</span>
          </h1>
          <p class="mt-4 text-lg text-muted-foreground">
            Whether you're looking for a demo, have questions about our platform,
            or need support — we're here to help.
          </p>
        </div>

        <div class="grid gap-10 lg:grid-cols-5 lg:gap-14">
          <!-- Contact info sidebar -->
          <div class="lg:col-span-2">
            <div class="space-y-4">
              <!-- Info card: Email -->
              <div class="group flex items-start gap-4 rounded-xl border border-border bg-card p-5 shadow-sm transition-all duration-200 hover:border-primary/30 hover:shadow-md">
                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-primary/10 text-primary transition-colors group-hover:bg-primary/15">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold">Email Us</h3>
                  <p class="mt-0.5 text-sm text-muted-foreground">hello@autolevelup.com</p>
                </div>
              </div>

              <!-- Info card: Response time -->
              <div class="group flex items-start gap-4 rounded-xl border border-border bg-card p-5 shadow-sm transition-all duration-200 hover:border-success/30 hover:shadow-md">
                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-success/10 text-success transition-colors group-hover:bg-success/15">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold">Response Time</h3>
                  <p class="mt-0.5 text-sm text-muted-foreground">We typically respond within 24 hours</p>
                </div>
              </div>

              <!-- Info card: Free demo -->
              <div class="group flex items-start gap-4 rounded-xl border border-border bg-card p-5 shadow-sm transition-all duration-200 hover:border-warning/30 hover:shadow-md">
                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-warning/10 text-warning transition-colors group-hover:bg-warning/15">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold">Free Demo</h3>
                  <p class="mt-0.5 text-sm text-muted-foreground">Request a personalized walkthrough of the platform</p>
                </div>
              </div>

              <!-- Trust badge -->
              <div class="mt-2 rounded-xl border border-dashed border-border bg-muted/30 p-5">
                <p class="text-sm text-muted-foreground">
                  <span class="font-semibold text-foreground">Trusted by 500+ schools</span> across the country.
                  Your data is always private and secure.
                </p>
              </div>
            </div>
          </div>

          <!-- Contact form -->
          <div class="lg:col-span-3">
            <div class="relative rounded-2xl border border-border bg-card shadow-lg">
              <!-- Gradient top accent -->
              <div class="absolute inset-x-0 top-0 h-px rounded-t-2xl bg-gradient-to-r from-transparent via-primary/50 to-transparent"></div>

              <div class="p-7 sm:p-9">
                <div class="mb-7">
                  <h2 class="text-2xl font-bold">Send Us a Message</h2>
                  <p class="mt-1.5 text-sm text-muted-foreground">
                    Fill out the form below and we'll get back to you soon.
                  </p>
                </div>

                <form id="contact-form" class="space-y-5" novalidate>
                  <!-- Honeypot -->
                  <div class="hidden" aria-hidden="true">
                    <input name="bot-field" tabindex="-1" autocomplete="off" />
                  </div>

                  <!-- Error summary -->
                  <div id="form-error-summary" class="hidden rounded-lg border border-destructive/30 bg-destructive/10 px-4 py-3 text-sm text-destructive" role="alert">
                    Please fix the errors below before submitting.
                  </div>

                  <!-- Name row -->
                  <div class="grid gap-5 sm:grid-cols-2">
                    <div class="space-y-1.5">
                      <label for="firstName" class="block text-sm font-medium">
                        First Name <span class="text-destructive">*</span>
                      </label>
                      <input
                        id="firstName"
                        name="firstName"
                        type="text"
                        required
                        autocomplete="given-name"
                        placeholder="John"
                        aria-describedby="firstName-error"
                        class="contact-input w-full rounded-lg border border-input bg-background px-3.5 py-2.5 text-sm shadow-sm outline-none transition-all duration-150 placeholder:text-muted-foreground/50 focus:border-primary focus:ring-2 focus:ring-primary/15"
                      />
                      <p class="hidden text-xs text-destructive" id="firstName-error" data-error="firstName" role="alert">Please enter your first name</p>
                    </div>
                    <div class="space-y-1.5">
                      <label for="lastName" class="block text-sm font-medium">
                        Last Name <span class="text-destructive">*</span>
                      </label>
                      <input
                        id="lastName"
                        name="lastName"
                        type="text"
                        required
                        autocomplete="family-name"
                        placeholder="Doe"
                        aria-describedby="lastName-error"
                        class="contact-input w-full rounded-lg border border-input bg-background px-3.5 py-2.5 text-sm shadow-sm outline-none transition-all duration-150 placeholder:text-muted-foreground/50 focus:border-primary focus:ring-2 focus:ring-primary/15"
                      />
                      <p class="hidden text-xs text-destructive" id="lastName-error" data-error="lastName" role="alert">Please enter your last name</p>
                    </div>
                  </div>

                  <!-- Email -->
                  <div class="space-y-1.5">
                    <label for="email" class="block text-sm font-medium">
                      Email Address <span class="text-destructive">*</span>
                    </label>
                    <div class="relative">
                      <svg class="pointer-events-none absolute left-3.5 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                      </svg>
                      <input
                        id="email"
                        name="email"
                        type="email"
                        required
                        autocomplete="email"
                        placeholder="john@school.edu"
                        aria-describedby="email-error"
                        class="contact-input w-full rounded-lg border border-input bg-background py-2.5 pr-3.5 pl-10 text-sm shadow-sm outline-none transition-all duration-150 placeholder:text-muted-foreground/50 focus:border-primary focus:ring-2 focus:ring-primary/15"
                      />
                    </div>
                    <p class="hidden text-xs text-destructive" id="email-error" data-error="email" role="alert">Please enter a valid email address</p>
                  </div>

                  <!-- Organization -->
                  <div class="space-y-1.5">
                    <label for="organization" class="block text-sm font-medium">
                      School / Organization
                    </label>
                    <div class="relative">
                      <svg class="pointer-events-none absolute left-3.5 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" />
                      </svg>
                      <input
                        id="organization"
                        name="organization"
                        type="text"
                        autocomplete="organization"
                        placeholder="Westbrook Academy"
                        class="contact-input w-full rounded-lg border border-input bg-background py-2.5 pr-3.5 pl-10 text-sm shadow-sm outline-none transition-all duration-150 placeholder:text-muted-foreground/50 focus:border-primary focus:ring-2 focus:ring-primary/15"
                      />
                    </div>
                  </div>

                  <!-- Role + Inquiry type row -->
                  <div class="grid gap-5 sm:grid-cols-2">
                    <div class="space-y-1.5">
                      <label for="role" class="block text-sm font-medium">
                        Your Role <span class="text-destructive">*</span>
                      </label>
                      <div class="relative">
                        <select
                          id="role"
                          name="role"
                          required
                          aria-describedby="role-error"
                          class="contact-input w-full appearance-none rounded-lg border border-input bg-background px-3.5 py-2.5 text-sm shadow-sm outline-none transition-all duration-150 focus:border-primary focus:ring-2 focus:ring-primary/15"
                        >
                          <option value="">Select your role</option>
                          <option value="administrator">School Administrator</option>
                          <option value="teacher">Teacher</option>
                          <option value="parent">Parent</option>
                          <option value="district">District Administrator</option>
                          <option value="other">Other</option>
                        </select>
                        <svg class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                        </svg>
                      </div>
                      <p class="hidden text-xs text-destructive" id="role-error" data-error="role" role="alert">Please select your role</p>
                    </div>

                    <div class="space-y-1.5">
                      <label for="inquiry" class="block text-sm font-medium">
                        Inquiry Type <span class="text-destructive">*</span>
                      </label>
                      <div class="relative">
                        <select
                          id="inquiry"
                          name="inquiry"
                          required
                          aria-describedby="inquiry-error"
                          class="contact-input w-full appearance-none rounded-lg border border-input bg-background px-3.5 py-2.5 text-sm shadow-sm outline-none transition-all duration-150 focus:border-primary focus:ring-2 focus:ring-primary/15"
                        >
                          <option value="">Select inquiry type</option>
                          <option value="demo">Request a Demo</option>
                          <option value="pricing">Pricing Question</option>
                          <option value="support">Technical Support</option>
                          <option value="partnership">Partnership Inquiry</option>
                          <option value="general">General Question</option>
                        </select>
                        <svg class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                        </svg>
                      </div>
                      <p class="hidden text-xs text-destructive" id="inquiry-error" data-error="inquiry" role="alert">Please select an inquiry type</p>
                    </div>
                  </div>

                  <!-- Message -->
                  <div class="space-y-1.5">
                    <label for="message" class="block text-sm font-medium">
                      Message <span class="text-destructive">*</span>
                    </label>
                    <textarea
                      id="message"
                      name="message"
                      required
                      rows="4"
                      placeholder="Tell us how we can help..."
                      aria-describedby="message-error"
                      class="contact-input w-full resize-none rounded-lg border border-input bg-background px-3.5 py-2.5 text-sm shadow-sm outline-none transition-all duration-150 placeholder:text-muted-foreground/50 focus:border-primary focus:ring-2 focus:ring-primary/15"
                    ></textarea>
                    <div class="flex items-center justify-between">
                      <p class="hidden text-xs text-destructive" id="message-error" data-error="message" role="alert">Please enter your message</p>
                      <p class="ml-auto text-xs text-muted-foreground" id="char-count"></p>
                    </div>
                  </div>

                  <!-- Submit -->
                  <button
                    type="submit"
                    id="submit-btn"
                    class="relative mt-1 flex w-full items-center justify-center gap-2.5 overflow-hidden rounded-lg bg-gray-900 px-6 py-3.5 text-sm font-semibold text-white shadow-md transition-all duration-200 ease-out hover:bg-gray-800 hover:shadow-lg active:scale-[0.98] disabled:cursor-not-allowed disabled:opacity-60"
                  >
                    <!-- Shimmer overlay shown during loading -->
                    <span id="btn-shimmer" class="absolute inset-0 hidden">
                      <span class="absolute inset-0 -translate-x-full animate-[shimmer_1.4s_infinite] bg-gradient-to-r from-transparent via-white/10 to-transparent"></span>
                    </span>

                    <svg id="submit-icon" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
                    </svg>

                    <!-- Dotted loader (3 bouncing dots) -->
                    <span id="submit-spinner" class="hidden items-center gap-1">
                      <span class="h-1.5 w-1.5 rounded-full bg-white animate-[bounce_0.8s_0ms_infinite]"></span>
                      <span class="h-1.5 w-1.5 rounded-full bg-white animate-[bounce_0.8s_150ms_infinite]"></span>
                      <span class="h-1.5 w-1.5 rounded-full bg-white animate-[bounce_0.8s_300ms_infinite]"></span>
                    </span>

                    <span id="submit-text">Send Message</span>
                  </button>
                </form>

                <!-- Success state (replaces form) -->
                <div id="form-success" class="hidden py-10 text-center" role="alert">
                  <div class="mx-auto mb-5 flex h-16 w-16 items-center justify-center rounded-full bg-success/10">
                    <svg class="h-8 w-8 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                  </div>
                  <h3 class="text-xl font-bold">Message Sent!</h3>
                  <p class="mt-2 text-sm text-muted-foreground">
                    Thank you! We've received your message and will get back to you within 24 hours.
                  </p>
                  <button
                    id="reset-form-btn"
                    type="button"
                    class="mt-6 inline-flex items-center gap-2 rounded-lg border border-border bg-background px-5 py-2.5 text-sm font-medium text-foreground shadow-sm transition-all duration-150 hover:border-primary/30 hover:bg-primary/5 active:scale-[0.98]"
                  >
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
                    </svg>
                    Send Another Message
                  </button>
                </div>

                <!-- Network error -->
                <div id="form-error" class="hidden mt-4 rounded-lg border border-destructive/20 bg-destructive/8 px-4 py-3 text-center text-sm text-destructive" role="alert">
                  Something went wrong. Please try again or email us at
                  <a href="mailto:hello@autolevelup.com" class="font-medium underline underline-offset-2">hello@autolevelup.com</a>.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script define:vars={{ APPSCRIPT_URL }}>
  function initContactForm() {
    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('submit-btn');
    const submitText = document.getElementById('submit-text');
    const submitSpinner = document.getElementById('submit-spinner');
    const submitIcon = document.getElementById('submit-icon');
    const successMsg = document.getElementById('form-success');
    const errorMsg = document.getElementById('form-error');
    const errorSummary = document.getElementById('form-error-summary');
    const messageField = document.getElementById('message');
    const charCount = document.getElementById('char-count');

    if (!form || !submitBtn) return;
    if (form.dataset.initialized) return;
    form.dataset.initialized = 'true';

    // Live char count on message
    if (messageField && charCount) {
      messageField.addEventListener('input', () => {
        const len = messageField.value.length;
        charCount.textContent = len > 0 ? `${len} characters` : '';
      });
    }

    function showError(field) {
      const el = document.querySelector(`[data-error="${field}"]`);
      const input = document.getElementById(field);
      if (el) el.classList.remove('hidden');
      if (input) {
        input.setAttribute('aria-invalid', 'true');
        input.classList.add('border-destructive', 'focus:border-destructive', 'focus:ring-destructive/15');
        input.classList.remove('border-input');
      }
    }

    function hideErrors() {
      document.querySelectorAll('[data-error]').forEach((el) => el.classList.add('hidden'));
      document.querySelectorAll('[aria-invalid]').forEach((el) => {
        el.removeAttribute('aria-invalid');
        el.classList.remove('border-destructive', 'focus:border-destructive', 'focus:ring-destructive/15');
        el.classList.add('border-input');
      });
      if (errorMsg) errorMsg.classList.add('hidden');
      if (errorSummary) errorSummary.classList.add('hidden');
    }

    function validateEmail(email) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    }

    const shimmer = document.getElementById('btn-shimmer');

    function setLoading(loading) {
      if (loading) {
        submitText.textContent = 'Sending…';
        submitSpinner.classList.remove('hidden');
        submitSpinner.classList.add('flex');
        submitIcon.classList.add('hidden');
        shimmer.classList.remove('hidden');
        submitBtn.setAttribute('disabled', 'true');
      } else {
        submitText.textContent = 'Send Message';
        submitSpinner.classList.add('hidden');
        submitSpinner.classList.remove('flex');
        submitIcon.classList.remove('hidden');
        shimmer.classList.add('hidden');
        submitBtn.removeAttribute('disabled');
      }
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      hideErrors();

      const data = new FormData(form);
      let valid = true;
      const invalidFields = [];

      for (const field of ['firstName', 'lastName', 'email', 'role', 'inquiry', 'message']) {
        const value = data.get(field)?.trim();
        if (!value) {
          showError(field);
          invalidFields.push(field);
          valid = false;
        }
      }

      const email = data.get('email')?.trim();
      if (email && !validateEmail(email)) {
        showError('email');
        if (!invalidFields.includes('email')) invalidFields.push('email');
        valid = false;
      }

      if (!valid) {
        errorSummary.classList.remove('hidden');
        const firstErrorEl = document.getElementById(invalidFields[0]);
        if (firstErrorEl) {
          firstErrorEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
          firstErrorEl.focus();
        }
        return;
      }

      setLoading(true);

      const params = new URLSearchParams({
        firstName: data.get('firstName')?.trim() ?? '',
        lastName: data.get('lastName')?.trim() ?? '',
        email: data.get('email')?.trim() ?? '',
        organization: data.get('organization')?.trim() ?? '',
        role: data.get('role') ?? '',
        inquiryType: data.get('inquiry') ?? '',
        message: data.get('message')?.trim() ?? '',
      });

      try {
        const url = `${APPSCRIPT_URL}?${params.toString()}`;
        console.log('[Contact] GET:', url);
        await fetch(url, { method: 'GET', redirect: 'follow' });
      } catch (err) {
        console.warn('[Contact] Fetch error (data still likely saved):', err);
      } finally {
        form.classList.add('hidden');
        successMsg.classList.remove('hidden');
        setLoading(false);
      }
    });

    // Reset form button
    const resetBtn = document.getElementById('reset-form-btn');
    if (resetBtn) {
      resetBtn.addEventListener('click', () => {
        form.reset();
        if (charCount) charCount.textContent = '';
        hideErrors();
        successMsg.classList.add('hidden');
        form.classList.remove('hidden');
        form.querySelector('input')?.focus();
      });
    }

    // Clear error state on input change
    form.querySelectorAll('input, select, textarea').forEach((el) => {
      el.addEventListener('change', () => {
        const field = el.id;
        const errorEl = document.querySelector(`[data-error="${field}"]`);
        if (errorEl && !errorEl.classList.contains('hidden')) {
          errorEl.classList.add('hidden');
          el.removeAttribute('aria-invalid');
          el.classList.remove('border-destructive', 'focus:border-destructive', 'focus:ring-destructive/15');
          el.classList.add('border-input');
        }
      });
    });
  }

  initContactForm();
  document.addEventListener('astro:after-swap', initContactForm);
</script>
