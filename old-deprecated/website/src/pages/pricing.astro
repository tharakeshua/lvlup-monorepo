---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';

const plans = [
  {
    name: 'Starter',
    price: 'Free',
    period: 'to get started',
    description: 'For individual teachers exploring the platform',
    highlight: false,
    features: [
      'Up to 30 students',
      'Build learning spaces with 15 question types',
      'Manual grading tools',
      'Student progress tracking',
      'Basic analytics dashboard',
      'Email support',
    ],
    cta: 'Get Started',
    href: '/demo',
  },
  {
    name: 'School',
    price: 'Custom',
    period: 'per school',
    description: 'For schools ready to bring AI grading and learning to every classroom',
    highlight: true,
    badge: 'Most Popular',
    features: [
      'Unlimited students and teachers',
      'AutoGrade — AI exam grading with feedback',
      'AI tutor and adaptive learning for every student',
      'School-wide analytics and at-risk alerts',
      'Parent portal with real-time updates',
      'Custom branding for your school',
      'Full gamification — XP, badges, leaderboards',
      'Dedicated onboarding support',
    ],
    cta: 'Book a Demo',
    href: '/demo',
  },
  {
    name: 'District',
    price: 'Custom',
    period: 'per district',
    description: 'For districts managing multiple schools from one dashboard',
    highlight: false,
    features: [
      'Everything in School, plus:',
      'Multi-school management from one view',
      'District-wide analytics and reporting',
      'Centralised user management',
      'Data export for board reviews and audits',
      'Dedicated account manager',
      'Priority support with SLA',
    ],
    cta: 'Schedule a Call',
    href: '/contact?plan=district',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Pricing — Auto-LevelUp',
  description: 'Simple pricing for every school size. Start free, then scale with custom plans for schools and districts.',
};
---

<Layout
  title="Pricing — Auto-LevelUp"
  description="Simple pricing for every school size. Start free, then get a custom plan for your school or district. AI grading and personalised learning included."
  jsonLd={jsonLd}
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Pricing', url: '/pricing' }]}
>
  <Nav />
  <main id="main-content">
    <!-- Pricing header -->
    <section class="pt-28 pb-8 sm:pt-36 sm:pb-12">
      <div class="mx-auto max-w-7xl px-4 text-center sm:px-6 lg:px-8">
        <div class="mb-4 inline-flex rounded-full bg-primary/10 px-4 py-1 text-sm font-medium text-primary">
          Simple Pricing
        </div>
        <h1 class="section-heading">
          Simple Plans for Every School
        </h1>
        <p class="section-subheading">
          Start free as an individual teacher. When your school is ready,
          we'll build a plan around your needs — no hidden fees.
        </p>
      </div>
    </section>

    <!-- Pricing grid -->
    <section class="pb-20 sm:pb-28">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid gap-6 lg:grid-cols-3">
          {plans.map((plan, i) => (
            <div
              class={`scroll-reveal relative flex flex-col rounded-xl border p-6 ${
                plan.highlight
                  ? 'border-primary bg-card shadow-lg shadow-primary/10 ring-1 ring-primary'
                  : 'border-border bg-card shadow-sm'
              }`}
              style={`transition-delay: ${i * 100}ms`}
              role="group"
              aria-label={`${plan.name} plan - ${plan.price} ${plan.period}`}
            >
              {plan.highlight && 'badge' in plan && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-primary px-4 py-1 text-xs font-semibold text-primary-foreground">
                  {plan.badge}
                </div>
              )}

              <div class="mb-6">
                <h3 class="text-lg font-bold">{plan.name}</h3>
                <p class="mt-1 text-sm text-muted-foreground">{plan.description}</p>
                <div class="mt-4">
                  <span class="text-4xl font-extrabold">{plan.price}</span>
                  <span class="text-sm text-muted-foreground">/{plan.period}</span>
                </div>
              </div>

              <ul class="mb-8 flex-1 space-y-3">
                {plan.features.map((feature) => (
                  <li class="flex items-start gap-2 text-sm">
                    <svg class={`mt-0.5 h-4 w-4 shrink-0 ${plan.highlight ? 'text-primary' : 'text-success'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="text-muted-foreground">{feature}</span>
                  </li>
                ))}
              </ul>

              <a
                href={plan.href}
                class={plan.highlight
                  ? 'btn-primary w-full text-center'
                  : 'btn-secondary w-full text-center'}
              >
                {plan.cta}
              </a>
            </div>
          ))}
        </div>

        <!-- FAQ note -->
        <div class="mt-12 text-center">
          <p class="text-sm text-muted-foreground">
            Have questions about pricing?{' '}
            <a href="/#faq" class="font-medium text-primary hover:underline">Check our FAQ</a>
            {' '}or{' '}
            <a href="/contact" class="font-medium text-primary hover:underline">contact us</a>.
          </p>
        </div>

        <!-- Comparison table -->
        <div class="mt-20 scroll-reveal overflow-x-auto">
          <h2 class="mb-8 text-center text-2xl font-bold">Feature Comparison</h2>
          <table class="w-full min-w-[600px] text-sm">
            <thead>
              <tr class="border-b border-border">
                <th class="pb-4 pr-4 text-left font-semibold">Feature</th>
                <th class="pb-4 px-4 text-center font-semibold">Starter</th>
                <th class="pb-4 px-4 text-center font-semibold text-primary">School</th>
                <th class="pb-4 pl-4 text-center font-semibold">District</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border">
              {[
                ['Students', '30', 'Unlimited', 'Unlimited'],
                ['AI Exam Grading (AutoGrade)', '-', 'Yes', 'Yes'],
                ['AI Tutor & Adaptive Learning', 'Basic', 'Full', 'Full'],
                ['15 Question Types', 'Yes', 'Yes', 'Yes'],
                ['Gamification (XP, Badges, Leaderboards)', 'Basic', 'Full', 'Full'],
                ['Analytics & At-Risk Alerts', 'Basic', 'School-wide', 'District-wide'],
                ['Parent Portal', '-', 'Yes', 'Yes'],
                ['Custom School Branding', '-', 'Yes', 'Yes'],
                ['Multi-School Management', '-', '-', 'Yes'],
                ['Dedicated Support & SLA', '-', 'Yes', 'Yes'],
                ['Data Export for Board Reviews', '-', 'Yes', 'Yes'],
              ].map(([feature, ...values]) => (
                <tr>
                  <td class="py-3 pr-4 font-medium">{feature}</td>
                  {values.map((val, j) => (
                    <td class={`py-3 px-4 text-center text-muted-foreground ${j === 1 ? 'bg-primary/5' : ''}`}>
                      {val === 'Yes' ? (
                        <svg class="mx-auto h-4 w-4 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                      ) : val === '-' ? (
                        <span class="text-muted-foreground/40">-</span>
                      ) : val}
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <CTA />
  </main>
  <Footer />
</Layout>
