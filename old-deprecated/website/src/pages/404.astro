---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Page Not Found - Auto LevelUp"
  description="The page you're looking for doesn't exist. Let's get you back on track."
>
  <Nav />
  <main id="main-content">
    <section class="flex min-h-[60vh] items-center pt-28 pb-20 sm:pt-36 sm:pb-28">
      <div class="mx-auto max-w-2xl px-4 text-center sm:px-6 lg:px-8">
        <!-- Animated 404 illustration -->
        <div class="relative mx-auto mb-8 h-48 w-48">
          <div class="error-float absolute inset-0 flex items-center justify-center">
            <span class="text-8xl font-extrabold text-primary/20">404</span>
          </div>
          <div class="error-float-delayed absolute inset-0 flex items-center justify-center">
            <svg class="h-24 w-24 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
            </svg>
          </div>
        </div>

        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Page Not Found</h1>
        <p class="mt-4 text-lg text-muted-foreground">
          Oops! This page seems to have leveled up past our sitemap.
          Let's get you back to familiar territory.
        </p>

        <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href="/" class="btn-primary px-6 py-3">
            Back to Home
            <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
            </svg>
          </a>
          <a href="/contact" class="btn-secondary px-6 py-3">Contact Support</a>
        </div>

        <!-- Helpful links -->
        <div class="mt-12 text-sm text-muted-foreground">
          <p class="font-medium text-foreground">Popular pages:</p>
          <div class="mt-3 flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
            <a href="/#features" class="text-primary hover:underline">Features</a>
            <a href="/pricing" class="text-primary hover:underline">Pricing</a>
            <a href="/#faq" class="text-primary hover:underline">FAQ</a>
            <a href="/blog" class="text-primary hover:underline">Blog</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  @keyframes error-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  @keyframes error-float-delayed {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-15px) rotate(5deg); }
  }
  .error-float {
    animation: error-float 3s ease-in-out infinite;
  }
  .error-float-delayed {
    animation: error-float-delayed 3s ease-in-out 0.5s infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .error-float, .error-float-delayed {
      animation: none;
    }
  }
</style>
