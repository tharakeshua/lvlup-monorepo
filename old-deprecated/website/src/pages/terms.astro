---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Terms of Service - Auto LevelUp',
  description: 'Terms and conditions for using the Auto LevelUp educational platform.',
};
---

<Layout
  title="Terms of Service - Auto LevelUp"
  description="Terms and conditions for using the Auto LevelUp educational platform. Read about account terms, acceptable use, and more."
  jsonLd={jsonLd}
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Terms of Service', url: '/terms' }]}
>
  <Nav />
  <main id="main-content">
    <section class="pt-28 pb-20 sm:pt-36 sm:pb-28">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Terms of Service</h1>
        <p class="mt-2 text-sm text-muted-foreground">Last updated: March 8, 2026</p>

        <div class="mt-10 space-y-8 text-sm leading-relaxed text-muted-foreground">
          <section>
            <h2 class="mb-3 text-lg font-semibold text-foreground">1. Account Terms</h2>
            <ul class="list-disc space-y-1 pl-6">
              <li>You must be at least 13 years old to create an account, or have your parent/guardian or school administrator create one on your behalf</li>
              <li>You are responsible for maintaining the security of your account credentials</li>
              <li>One person or legal entity may not maintain more than one free account</li>
              <li>You must provide accurate and complete information during registration</li>
              <li>School administrators are responsible for managing user accounts within their institution</li>
            </ul>
          </section>

          <section>
            <h2 class="mb-3 text-lg font-semibold text-foreground">2. Acceptable Use</h2>
            <p class="mb-3">You agree to use Auto LevelUp only for lawful educational purposes. You may not:</p>
            <ul class="list-disc space-y-1 pl-6">
              <li>Use the platform to harass, bully, or discriminate against any user</li>
              <li>Upload malicious content, viruses, or harmful code</li>
              <li>Attempt to gain unauthorized access to other users' accounts or data</li>
              <li>Use AI AutoGrade outputs to make high-stakes decisions without human review</li>
              <li>Scrape, copy, or redistribute platform content without authorization</li>
              <li>Circumvent any rate limits, security measures, or access restrictions</li>
              <li>Use the platform for any commercial purpose unrelated to education</li>
            </ul>
          </section>

          <section>
            <h2 class="mb-3 text-lg font-semibold text-foreground">3. Service Level</h2>
            <p class="mb-3">We strive to maintain high availability and performance:</p>
            <ul class="list-disc space-y-1 pl-6">
              <li><strong>Uptime target:</strong> 99.9% for Pro and Enterprise plans</li>
              <li><strong>Scheduled maintenance:</strong> Announced at least 48 hours in advance, typically during off-peak hours</li>
              <li><strong>Data backups:</strong> Daily automated backups with 30-day retention</li>
              <li><strong>Support response:</strong> Within 24 hours for all plans; within 4 hours for Enterprise</li>
            </ul>
            <p class="mt-3">Enterprise customers receive a formal Service Level Agreement (SLA) with uptime guarantees and credits for downtime.</p>
          </section>

          <section>
            <h2 class="mb-3 text-lg font-semibold text-foreground">4. Intellectual Property</h2>
            <ul class="list-disc space-y-1 pl-6">
              <li><strong>Your content:</strong> You retain ownership of all content you upload, including assignments, tests, and educational materials</li>
              <li><strong>Our platform:</strong> Auto LevelUp retains all rights to the platform software, design, and documentation</li>
              <li><strong>AI-generated content:</strong> Feedback and grades generated by AI AutoGrade are provided as suggestions; schools retain editorial control</li>
              <li><strong>Student work:</strong> Student submissions remain the property of the student and their school</li>
            </ul>
          </section>

          <section>
            <h2 class="mb-3 text-lg font-semibold text-foreground">5. Termination</h2>
            <p class="mb-3">Either party may terminate the agreement:</p>
            <ul class="list-disc space-y-1 pl-6">
              <li>You may cancel your account at any time through your account settings</li>
              <li>We may suspend or terminate accounts that violate these terms</li>
              <li>Upon termination, you may request a data export within 30 days</li>
              <li>We will delete your data within 90 days of account closure, subject to legal retention requirements</li>
              <li>Prepaid fees for unused subscription periods are refundable on a pro-rata basis</li>
            </ul>
          </section>

          <section>
            <h2 class="mb-3 text-lg font-semibold text-foreground">6. Limitation of Liability</h2>
            <p class="mb-3">To the maximum extent permitted by law:</p>
            <ul class="list-disc space-y-1 pl-6">
              <li>Auto LevelUp is provided "as is" without warranties of any kind</li>
              <li>We are not liable for indirect, incidental, or consequential damages</li>
              <li>Our total liability shall not exceed the fees paid in the 12 months preceding the claim</li>
              <li>AI-generated grades and feedback should be reviewed by qualified educators before final use</li>
              <li>We do not guarantee specific educational outcomes</li>
            </ul>
          </section>

          <section>
            <h2 class="mb-3 text-lg font-semibold text-foreground">7. Changes to Terms</h2>
            <p>We may update these terms from time to time. Material changes will be communicated via email and an in-app notification at least 30 days before taking effect. Continued use of the platform after changes take effect constitutes acceptance of the updated terms.</p>
          </section>

          <section>
            <h2 class="mb-3 text-lg font-semibold text-foreground">8. Contact</h2>
            <p>Questions about these terms? <a href="/contact" class="font-medium text-primary hover:underline">Contact us</a> or email <strong>legal@autolevelup.com</strong>.</p>
          </section>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
