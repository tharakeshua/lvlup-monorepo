---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Cookie Policy - Auto LevelUp',
  description: 'Learn about how Auto LevelUp uses cookies and similar technologies.',
};
---

<Layout
  title="Cookie Policy - Auto LevelUp"
  description="Learn about how Auto LevelUp uses cookies and similar technologies on our website and platform."
  jsonLd={jsonLd}
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Cookie Policy', url: '/cookies' }]}
>
  <Nav />
  <main id="main-content">
    <section class="pt-28 pb-20 sm:pt-36 sm:pb-28">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Cookie Policy</h1>
        <p class="mt-2 text-sm text-muted-foreground">Last updated: March 8, 2026</p>

        <div class="mt-10 space-y-8 text-sm leading-relaxed text-muted-foreground">
          <section>
            <h2 class="mb-3 text-lg font-semibold text-foreground">What Are Cookies</h2>
            <p>Cookies are small text files stored on your device when you visit a website. They help the site remember your preferences and improve your browsing experience. Auto LevelUp uses cookies and similar technologies (such as local storage) to provide, protect, and improve our platform.</p>
          </section>

          <section>
            <h2 class="mb-3 text-lg font-semibold text-foreground">Cookie Types We Use</h2>

            <!-- Cookie table -->
            <div class="mt-4 overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-border">
                    <th class="pb-3 pr-4 text-left font-semibold text-foreground">Type</th>
                    <th class="pb-3 pr-4 text-left font-semibold text-foreground">Purpose</th>
                    <th class="pb-3 text-left font-semibold text-foreground">Duration</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-border">
                  <tr>
                    <td class="py-3 pr-4 font-medium text-foreground">Essential</td>
                    <td class="py-3 pr-4">Required for the platform to function. Includes authentication tokens, session management, and CSRF protection.</td>
                    <td class="py-3">Session / 30 days</td>
                  </tr>
                  <tr>
                    <td class="py-3 pr-4 font-medium text-foreground">Analytics</td>
                    <td class="py-3 pr-4">Help us understand how visitors use our website and platform. We use this data to improve functionality and user experience.</td>
                    <td class="py-3">Up to 2 years</td>
                  </tr>
                  <tr>
                    <td class="py-3 pr-4 font-medium text-foreground">Preferences</td>
                    <td class="py-3 pr-4">Remember your settings and choices, such as language, theme (light/dark mode), and notification preferences.</td>
                    <td class="py-3">1 year</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </section>

          <section>
            <h2 class="mb-3 text-lg font-semibold text-foreground">Essential Cookies</h2>
            <p class="mb-3">These cookies are strictly necessary for the platform to operate. They cannot be disabled. They include:</p>
            <ul class="list-disc space-y-1 pl-6">
              <li><strong>Authentication:</strong> Keep you signed in securely across sessions</li>
              <li><strong>Security:</strong> CSRF tokens and session validation to prevent unauthorized actions</li>
              <li><strong>Load balancing:</strong> Distribute requests across our servers for optimal performance</li>
              <li><strong>Consent preferences:</strong> Remember your cookie consent choices</li>
            </ul>
          </section>

          <section>
            <h2 class="mb-3 text-lg font-semibold text-foreground">Analytics Cookies</h2>
            <p class="mb-3">We use analytics to understand usage patterns and improve the platform:</p>
            <ul class="list-disc space-y-1 pl-6">
              <li>Page views and navigation patterns (which features are most used)</li>
              <li>Session duration and engagement metrics</li>
              <li>Error tracking to identify and fix issues quickly</li>
              <li>Performance metrics (page load times, API response times)</li>
            </ul>
            <p class="mt-3">We do not use analytics data to personally identify individual users. Student usage data is processed in compliance with FERPA and COPPA.</p>
          </section>

          <section>
            <h2 class="mb-3 text-lg font-semibold text-foreground">How to Manage Cookies</h2>
            <p class="mb-3">You can control cookies through your browser settings:</p>
            <ul class="list-disc space-y-1 pl-6">
              <li><strong>Chrome:</strong> Settings &gt; Privacy and Security &gt; Cookies and other site data</li>
              <li><strong>Firefox:</strong> Settings &gt; Privacy & Security &gt; Cookies and Site Data</li>
              <li><strong>Safari:</strong> Preferences &gt; Privacy &gt; Manage Website Data</li>
              <li><strong>Edge:</strong> Settings &gt; Cookies and site permissions</li>
            </ul>
            <p class="mt-3">Please note that disabling essential cookies may prevent the platform from functioning correctly.</p>
          </section>

          <section>
            <h2 class="mb-3 text-lg font-semibold text-foreground">Third-Party Cookies</h2>
            <p class="mb-3">We minimize the use of third-party cookies. The following third-party services may set cookies:</p>
            <ul class="list-disc space-y-1 pl-6">
              <li><strong>Google Fonts:</strong> Font delivery (no tracking cookies)</li>
              <li><strong>Analytics provider:</strong> Privacy-focused analytics with anonymized data</li>
            </ul>
            <p class="mt-3">We do not use advertising cookies or allow ad networks to track users on our platform.</p>
          </section>

          <section>
            <h2 class="mb-3 text-lg font-semibold text-foreground">Updates to This Policy</h2>
            <p>We may update this cookie policy periodically. Changes will be posted on this page with an updated revision date. For questions, <a href="/contact" class="font-medium text-primary hover:underline">contact us</a> or email <strong>privacy@autolevelup.com</strong>.</p>
          </section>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
