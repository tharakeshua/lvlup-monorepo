      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local",
        "src",
        "package.json.bak"
      ]
    },
    {
      "source": "functions/sdk-v1",
      "codebase": "sdk-v1",
      "runtime": "nodejs20",
      "predeploy": [
        "pnpm -F @levelup/functions-sdk-v1 build",
        "node functions/sdk-v1/scripts/prepare-deploy-pkg.mjs"
      ],
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local",
        "src",
        "scripts",
        "package.json.bak"
      ]
    }
  ],
  "hosting": [
    {
      "target": "admin-web",
      "public": "apps/admin-web/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "**/*.@(js|css|map)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        }
      ]
    },
