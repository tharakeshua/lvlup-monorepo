{
  "functions": [
    {
      "source": "functions/identity",
      "codebase": "identity",
      "runtime": "nodejs20",
      "predeploy": [],
      "postdeploy": ["npx tsx scripts/prepare-functions-deploy.ts cleanup identity"],
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local",
        "src",
        "package.json.bak"
      ]
    },
    {
      "source": "functions/autograde",
      "codebase": "autograde",
      "runtime": "nodejs20",
      "predeploy": [],
      "postdeploy": ["npx tsx scripts/prepare-functions-deploy.ts cleanup autograde"],
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local",
        "src",
        "package.json.bak"
      ]
    },
    {
      "source": "functions/levelup",
      "codebase": "levelup",
      "runtime": "nodejs20",
      "predeploy": [],
      "postdeploy": ["npx tsx scripts/prepare-functions-deploy.ts cleanup levelup"],
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local",
        "src",
        "package.json.bak"
      ]
    },
    {
      "source": "functions/analytics",
      "codebase": "analytics",
      "runtime": "nodejs20",
