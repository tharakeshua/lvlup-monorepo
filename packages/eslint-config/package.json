{
  "name": "@levelup/eslint-config",
  "version": "0.1.0",
  "private": true,
  "description": "Shared ESLint configuration for LevelUp monorepo",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./react": "./react.js",
    "./node": "./node.js",
    "./presets": "./src/presets.mjs",
    "./boundaries": "./src/boundaries.mjs",
    "./tiers": "./src/tiers.mjs"
  },
  "files": [
    "index.js",
    "react.js",
    "node.js",
    "src"
  ],
  "dependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^5.2.0"
  },
  "peerDependencies": {
    "eslint": "^8.0.0 || ^9.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "eslint",
    "eslintconfig",
    "typescript",
    "react"
  ]
}
